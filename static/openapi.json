{
  "openapi": "3.0.3",
  "info": {
    "title": "CMMC Artifact Tracker API",
    "description": "API for managing CMMC (Cybersecurity Maturity Model Certification) assessment artifacts, objectives, assignments, and compliance tracking. All endpoints require authentication via session cookie. Mutating endpoints require an X-CSRF-Token header.",
    "version": "1.0.0",
    "contact": {
      "name": "CMMC Tracker"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3300",
      "description": "Local development"
    }
  ],
  "tags": [
    {"name": "Auth", "description": "Authentication and user setup"},
    {"name": "Dashboard", "description": "Dashboard and search"},
    {"name": "Objectives", "description": "Objective status, toggle, and notes"},
    {"name": "Artifacts", "description": "File upload, linking, and management"},
    {"name": "Assignments", "description": "Objective assignments to team members"},
    {"name": "Team", "description": "Team members and domains"},
    {"name": "POA&M", "description": "Plan of Action & Milestones"},
    {"name": "SSP", "description": "System Security Plan mappings"},
    {"name": "Comments", "description": "Objective comments and activity log"},
    {"name": "Reports", "description": "CSV export and assessment reports"},
    {"name": "Notifications", "description": "Overdue assignment alerts and email"},
    {"name": "Organizations", "description": "Multi-tenant organization management"},
    {"name": "Admin", "description": "User administration (admin only)"},
    {"name": "Backup", "description": "Import/export full state as ZIP"}
  ],
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session"
      },
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-Token"
      }
    },
    "schemas": {
      "Objective": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "example": "3.1.1[a]"},
          "family": {"type": "string", "example": "Access Control"},
          "requirement_id": {"type": "string", "example": "3.1.1"},
          "assessment_objective": {"type": "string"},
          "captured": {"type": "integer", "enum": [0, 1]},
          "status": {"type": "string", "enum": ["Not Started", "In Progress", "Evidence Collected", "Reviewed", "Complete"]},
          "artifact_notes": {"type": "string"},
          "captured_date": {"type": "string", "format": "date", "nullable": true}
        }
      },
      "Artifact": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "objective_id": {"type": "string"},
          "filename": {"type": "string"},
          "original_name": {"type": "string"},
          "file_size": {"type": "integer"},
          "mime_type": {"type": "string"},
          "uploaded_at": {"type": "string", "format": "date-time"},
          "domain_id": {"type": "integer", "nullable": true},
          "domain_name": {"type": "string", "nullable": true},
          "domain_color": {"type": "string", "nullable": true},
          "file_created": {"type": "string", "nullable": true},
          "obtained_method": {"type": "string"},
          "linked_objectives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "family": {"type": "string"}
              }
            }
          }
        }
      },
      "Assignment": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "objective_id": {"type": "string"},
          "member_id": {"type": "integer"},
          "member_name": {"type": "string"},
          "member_role": {"type": "string"},
          "status": {"type": "string"},
          "due_date": {"type": "string", "format": "date", "nullable": true},
          "assigned_at": {"type": "string", "format": "date-time"}
        }
      },
      "TeamMember": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "role": {"type": "string"},
          "email": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "color": {"type": "string", "example": "#6366f1"}
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "slug": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"},
          "user_count": {"type": "integer"}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "username": {"type": "string"},
          "role": {"type": "string", "enum": ["admin", "user"]},
          "first_name": {"type": "string"},
          "last_name": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "objective_id": {"type": "string"},
          "user_id": {"type": "integer"},
          "username": {"type": "string"},
          "comment": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "SSPMapping": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "requirement_id": {"type": "string"},
          "ssp_section": {"type": "string"},
          "ssp_description": {"type": "string"}
        }
      },
      "OkResponse": {
        "type": "object",
        "properties": {
          "ok": {"type": "boolean", "example": true}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string"}
        }
      }
    }
  },
  "security": [
    {"sessionAuth": []},
    {"csrfToken": []}
  ],
  "paths": {
    "/api/search": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Search objectives",
        "description": "Search objectives by ID, text, family, requirement ID, or security requirement. Results scoped to current organization.",
        "parameters": [
          {"name": "q", "in": "query", "required": true, "schema": {"type": "string"}, "description": "Search query"}
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Objective"}
                }
              }
            }
          }
        }
      }
    },
    "/api/toggle": {
      "post": {
        "tags": ["Objectives"],
        "summary": "Toggle objective completion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {"type": "string", "example": "3.1.1[a]"},
                  "captured": {"type": "boolean"},
                  "artifact_notes": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/status": {
      "post": {
        "tags": ["Objectives"],
        "summary": "Update objective status",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "status"],
                "properties": {
                  "id": {"type": "string"},
                  "status": {"type": "string", "enum": ["Not Started", "In Progress", "Evidence Collected", "Reviewed", "Complete"]}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {"type": "boolean"},
                    "status": {"type": "string"},
                    "captured": {"type": "integer"}
                  }
                }
              }
            }
          },
          "400": {"description": "Invalid status", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/notes": {
      "post": {
        "tags": ["Objectives"],
        "summary": "Update objective notes",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {"type": "string"},
                  "notes": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/bulk": {
      "post": {
        "tags": ["Objectives"],
        "summary": "Bulk update requirement objectives",
        "description": "Set all objectives under a requirement to captured/uncaptured.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["requirement_id"],
                "properties": {
                  "requirement_id": {"type": "string", "example": "3.1.1"},
                  "captured": {"type": "boolean", "default": true}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/artifacts/{objective_id}": {
      "get": {
        "tags": ["Artifacts"],
        "summary": "List artifacts for an objective",
        "parameters": [
          {"name": "objective_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Artifact list",
            "content": {
              "application/json": {
                "schema": {"type": "array", "items": {"$ref": "#/components/schemas/Artifact"}}
              }
            }
          }
        }
      }
    },
    "/api/upload": {
      "post": {
        "tags": ["Artifacts"],
        "summary": "Upload an artifact",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["objective_id", "file"],
                "properties": {
                  "objective_id": {"type": "string"},
                  "file": {"type": "string", "format": "binary"},
                  "domain_id": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {"type": "boolean"},
                    "filename": {"type": "string"}
                  }
                }
              }
            }
          },
          "400": {"description": "Validation error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/artifacts/delete/{artifact_id}": {
      "post": {
        "tags": ["Artifacts"],
        "summary": "Delete an artifact",
        "parameters": [
          {"name": "artifact_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}},
          "404": {"description": "Not found", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/artifacts/{artifact_id}/domain": {
      "patch": {
        "tags": ["Artifacts"],
        "summary": "Update artifact domain tag",
        "parameters": [
          {"name": "artifact_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domain_id": {"type": "integer", "nullable": true}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/artifacts/{artifact_id}/obtained": {
      "patch": {
        "tags": ["Artifacts"],
        "summary": "Update artifact obtained method",
        "parameters": [
          {"name": "artifact_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "obtained_method": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/artifacts/{artifact_id}/link": {
      "post": {
        "tags": ["Artifacts"],
        "summary": "Link artifact to another objective",
        "parameters": [
          {"name": "artifact_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["objective_id"],
                "properties": {
                  "objective_id": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}},
          "409": {"description": "Already linked", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/artifacts/{artifact_id}/link/{objective_id}": {
      "delete": {
        "tags": ["Artifacts"],
        "summary": "Unlink artifact from objective",
        "parameters": [
          {"name": "artifact_id", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "objective_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}},
          "400": {"description": "Cannot unlink last objective", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/artifacts/library": {
      "get": {
        "tags": ["Artifacts"],
        "summary": "List all artifacts",
        "description": "Returns all artifacts for the current organization with linked objectives.",
        "responses": {
          "200": {
            "description": "Artifact library",
            "content": {
              "application/json": {
                "schema": {"type": "array", "items": {"$ref": "#/components/schemas/Artifact"}}
              }
            }
          }
        }
      }
    },
    "/api/hash-artifacts": {
      "post": {
        "tags": ["Artifacts"],
        "summary": "Generate SHA-256 hashes for all artifacts",
        "description": "Creates CMMC-compliant hash logs for artifact integrity verification.",
        "responses": {
          "200": {
            "description": "Hash results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {"type": "boolean"},
                    "artifacts_hashed": {"type": "integer"},
                    "log_hash": {"type": "string"},
                    "artifacts_log": {"type": "string"},
                    "hash_log": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/assignments/{objective_id}": {
      "get": {
        "tags": ["Assignments"],
        "summary": "List assignments for an objective",
        "parameters": [
          {"name": "objective_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Assignment list",
            "content": {
              "application/json": {
                "schema": {"type": "array", "items": {"$ref": "#/components/schemas/Assignment"}}
              }
            }
          }
        }
      }
    },
    "/api/assignments": {
      "post": {
        "tags": ["Assignments"],
        "summary": "Create an assignment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["objective_id", "member_id"],
                "properties": {
                  "objective_id": {"type": "string"},
                  "member_id": {"type": "integer"},
                  "status": {"type": "string", "default": "assigned"},
                  "due_date": {"type": "string", "format": "date"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}},
          "409": {"description": "Already assigned", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/assignments/{assignment_id}": {
      "delete": {
        "tags": ["Assignments"],
        "summary": "Delete an assignment",
        "parameters": [
          {"name": "assignment_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/assignments/{assignment_id}/due": {
      "patch": {
        "tags": ["Assignments"],
        "summary": "Update assignment due date",
        "parameters": [
          {"name": "assignment_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "due_date": {"type": "string", "format": "date", "nullable": true}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/assignments/{assignment_id}/status": {
      "patch": {
        "tags": ["Assignments"],
        "summary": "Update assignment status",
        "parameters": [
          {"name": "assignment_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/assignments/bulk": {
      "post": {
        "tags": ["Assignments"],
        "summary": "Bulk assign a requirement group",
        "description": "Assigns all objectives under a requirement to a team member, skipping duplicates.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["requirement_id", "member_id"],
                "properties": {
                  "requirement_id": {"type": "string"},
                  "member_id": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk assign result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {"type": "boolean"},
                    "added": {"type": "integer"},
                    "total": {"type": "integer"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/team": {
      "get": {
        "tags": ["Team"],
        "summary": "List team members",
        "responses": {
          "200": {
            "description": "Team member list",
            "content": {
              "application/json": {
                "schema": {"type": "array", "items": {"$ref": "#/components/schemas/TeamMember"}}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Team"],
        "summary": "Add team member (admin only)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"},
                  "role": {"type": "string"},
                  "email": {"type": "string", "format": "email"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/team/{member_id}": {
      "patch": {
        "tags": ["Team"],
        "summary": "Update team member (admin only)",
        "parameters": [
          {"name": "member_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "role": {"type": "string"},
                  "email": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      },
      "delete": {
        "tags": ["Team"],
        "summary": "Delete team member (admin only)",
        "parameters": [
          {"name": "member_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
    "/api/domains": {
      "get": {
        "tags": ["Team"],
        "summary": "List domains/asset tags",
        "responses": {
          "200": {
            "description": "Domain list",
            "content": {
              "application/json": {
                "schema": {"type": "array", "items": {"$ref": "#/components/schemas/Domain"}}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Team"],
        "summary": "Add domain (admin only)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"},
                  "color": {"type": "string", "default": "#6366f1"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}},
          "409": {"description": "Already exists", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/api/domains/{domain_id}": {
      "patch": {
        "tags": ["Team"],
        "summary": "Update domain (admin only)",
        "parameters": [
          {"name": "domain_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "color": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      },
      "delete": {
        "tags": ["Team"],
        "summary": "Delete domain (admin only)",
        "parameters": [
          {"name": "domain_id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OkResponse"}}}}
        }
      }
    },
